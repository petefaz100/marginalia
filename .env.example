# marginalia — environment variables
# Copy this file to .env.local and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# Both of these are PUBLIC (safe to ship to the browser). Do NOT put the
# service_role key here — that one stays secret and is added later, if ever.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
